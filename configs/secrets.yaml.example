# Secrets configuration file
# Copie este arquivo para secrets.yaml e adicione suas chaves reais
# Este arquivo é git-ignored para não commitar secrets

# Chave da API OpenAI (necessária para LLM fallback e embeddings)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY: "sk-your-api-key-here"

